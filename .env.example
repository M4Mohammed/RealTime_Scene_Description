# ── Web-App Service ──────────────────────────────────────────────────────
# URL of the model-server (set automatically by Docker Compose)
MODEL_SERVER_URL=http://model-server:8080

# ── Model Server ─────────────────────────────────────────────────────────
# Which HuggingFace model to load (default: Salesforce/blip-image-captioning-base)
# MODEL_NAME=Salesforce/blip-image-captioning-base
# MAX_NEW_TOKENS=50